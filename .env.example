# Copy to .env and fill in. Never commit .env.
#
# Required for agent + CLOB
ANTHROPIC_API_KEY=
POLYGON_PRIVATE_KEY=
POLYMARKET_WALLET_ADDRESS=
BUILDER_CODE=

# Polymarket CLOB V2 (default matches embedded-wallet / deposit flow)
SIGNATURE_TYPE=POLY_1271

# Optional overrides
# AWS_REGION=eu-west-1
# DDB_REGION=us-west-2
# DDB_TABLE=geo-trading-positions
# S3_BUCKET=
# S3_FEEDBACK_KEY=geo-signals/feedback.csv
# FEEDBACK_CSV_PATH=/absolute/path/to/feedback.csv
# POLYGON_RPC=https://polygon-bor-rpc.publicnode.com
# DRY_RUN=true
