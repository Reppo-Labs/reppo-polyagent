# Copy to .env in this directory (gitignored). Never commit .env.
#
# Lambda uses:
#   POLYGON_PRIVATE_KEY       = MetaMask EOA that SIGNS orders
#   POLYMARKET_WALLET_ADDRESS = portfolio / proxy that HOLDS pUSD (funder)
# Deposit address is only for bridging on Polymarket UI — not read by the agent.

AGENT_VARIANT=A
POLYGON_PRIVATE_KEY=0x...
POLYMARKET_WALLET_ADDRESS=0x...
# POLYMARKET_DEPOSIT_ADDRESS=0x...   # reference only
SIGNATURE_TYPE=POLY_1271

ANTHROPIC_API_KEY=
BUILDER_CODE=

DRY_RUN=true
AWS_REGION=eu-west-1
STACK_NAME=ABC-AgentA
DDB_TABLE=abc-positions-a
